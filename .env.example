# OpenCode Go / Zen API key. Do not commit a real key.
OPENCODE_API_KEY=oc_YOUR_KEY_HERE

# Local proxy port for Claude Code.
PORT=8787

# OpenCode exposes Go/Zen models at this base.
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Default OpenAI-compatible model to use behind Claude Code.
# Pick one your OpenCode Go subscription has access to.
OPENCODE_GO_MODEL=kimi-k2.6

# Optional: force every Claude Code model request to this upstream model.
# OPENCODE_FORCE_MODEL=kimi-k2.6

# Optional JSON model map. Claude Code asks for Anthropic-ish model names;
# map them to OpenCode Go chat-completions models.
# OPENCODE_MODEL_MAP_JSON={"claude-sonnet-4-6":"kimi-k2.6","sonnet":"kimi-k2.6","haiku":"minimax-m2.5"}
