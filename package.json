{
  "name": "javiproxy",
  "version": "0.1.6",
  "description": "JaviProxy - OpenCode Go router for Claude Code",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "app": "node scripts/run-electron-vite.mjs dev",
    "dev": "node scripts/run-electron-vite.mjs dev",
    "start": "node scripts/run-electron-vite.mjs preview",
    "build": "electron-vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.javiproxy.app",
    "productName": "JaviProxy",
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 360,
          "type": "file",
          "path": "resources/LEER_ANTES_DE_ABRIR.txt"
        }
      ]
    },
    "extraResources": [
      {
        "from": "resources/LEER_ANTES_DE_ABRIR.txt",
        "to": "LEER_ANTES_DE_ABRIR.txt"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "JavierValdez",
      "repo": "JaviProxy",
      "releaseType": "release"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
